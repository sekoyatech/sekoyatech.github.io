---
import { NAV_ITEMS, SITE } from '../../lib/constants';
import { useTranslations } from '../../i18n/utils';
import ThemeToggle from '../ui/ThemeToggle.astro';

const t = useTranslations();
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border/50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 md:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-text font-bold text-xl hover:text-primary transition-colors" aria-label={`${SITE.name} - Home`}>
        <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 28L16 6L24 28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"/>
          <path d="M11 20L16 10L21 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary opacity-60"/>
          <line x1="16" y1="28" x2="16" y2="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-primary-dark"/>
        </svg>
        <span>{SITE.name}</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {NAV_ITEMS.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-md transition-colors',
                isActive
                  ? 'text-primary bg-primary/10'
                  : 'text-text-muted hover:text-text hover:bg-surface',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {t(item.label as any)}
            </a>
          );
        })}
        <div class="ml-2 pl-2 border-l border-border">
          <ThemeToggle />
        </div>
      </div>

      <!-- Mobile: Theme Toggle + Hamburger -->
      <div class="flex items-center gap-2 lg:hidden">
        <ThemeToggle />
        <label
          for="mobile-menu-toggle"
          class="flex items-center justify-center w-10 h-10 rounded-md text-text-muted hover:text-text hover:bg-surface transition-colors cursor-pointer"
          aria-label={t('common.menu_open')}
          role="button"
          tabindex="0"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </label>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu (CSS-only toggle via checkbox) -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
  <div class="fixed inset-0 z-50 bg-bg/95 backdrop-blur-lg transform translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out lg:hidden">
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between px-4 h-16 border-b border-border">
        <a href="/" class="text-text font-bold text-xl">{SITE.name}</a>
        <label
          for="mobile-menu-toggle"
          class="flex items-center justify-center w-10 h-10 rounded-md text-text-muted hover:text-text hover:bg-surface transition-colors cursor-pointer"
          aria-label={t('common.menu_close')}
          role="button"
          tabindex="0"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </label>
      </div>
      <nav class="flex-1 px-4 py-6 overflow-y-auto" aria-label="Mobile navigation">
        <div class="flex flex-col gap-1">
          {NAV_ITEMS.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  'px-4 py-3 text-base font-medium rounded-lg transition-colors',
                  isActive
                    ? 'text-primary bg-primary/10'
                    : 'text-text-muted hover:text-text hover:bg-surface',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {t(item.label as any)}
              </a>
            );
          })}
        </div>
      </nav>
    </div>
  </div>
</header>

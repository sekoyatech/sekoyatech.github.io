---
import { formatDate } from '../../lib/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  readingTime: number;
  tags?: string[];
  heroImage?: string;
  heroImageAlt?: string;
  slug?: string;
}

const {
  title,
  pubDate,
  updatedDate,
  author = 'Sekoya Team',
  readingTime,
  tags = [],
  heroImage,
  heroImageAlt,
  slug,
} = Astro.props;
const t = useTranslations();

const gradientColors = [
  'from-primary/20 to-secondary/10',
  'from-secondary/20 to-accent/10',
  'from-accent/20 to-primary/10',
];
const gradientIndex = tags.length > 0
  ? tags[0].split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % gradientColors.length
  : 0;
---

<header class="mb-12">
  {/* Hero image */}
  {heroImage ? (
    <div class="relative overflow-hidden rounded-xl mb-8 aspect-[21/9]">
      <img
        src={heroImage}
        alt={heroImageAlt || title}
        class="w-full h-full object-cover"
      />
    </div>
  ) : (
    <div class={`relative overflow-hidden rounded-xl mb-8 aspect-[21/9] bg-gradient-to-br ${gradientColors[gradientIndex]} flex items-center justify-center`}>
      <svg class="w-16 h-16 text-text-muted/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
      </svg>
    </div>
  )}

  {/* Metadata bar */}
  <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted mb-4">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    <span aria-hidden="true">&middot;</span>
    <span>{readingTime} {t('blog.reading_time')}</span>
    {author && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>{author}</span>
      </>
    )}
    {updatedDate && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>Updated: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
      </>
    )}
  </div>

  {/* Title */}
  <h1
    class="text-3xl md:text-5xl font-extrabold text-text mb-6"
    transition:name={slug ? `blog-title-${slug}` : undefined}
  >
    {title}
  </h1>

  {/* Tags */}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a
          href={`/blog/tags/${tag.toLowerCase()}/`}
          class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</header>

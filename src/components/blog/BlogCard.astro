---
import Card from '../ui/Card.astro';
import { formatDate } from '../../lib/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  href: string;
  readingTime?: number;
  slug?: string;
  heroImage?: string;
  heroImageAlt?: string;
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  href,
  readingTime,
  slug,
  heroImage,
  heroImageAlt,
  featured = false,
} = Astro.props;
const t = useTranslations();

const gradientColors = [
  'from-primary/20 to-secondary/10',
  'from-secondary/20 to-accent/10',
  'from-accent/20 to-primary/10',
  'from-primary/15 to-accent/15',
  'from-secondary/15 to-primary/15',
];
const gradientIndex = tags.length > 0
  ? tags[0].split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % gradientColors.length
  : 0;
---

<a href={href} class:list={["group block", featured && "md:col-span-2 lg:col-span-3"]}>
  <Card class="h-full group-hover:border-primary/30" padding="none">
    <div class:list={["flex flex-col h-full", featured && "md:flex-row"]}>
      {/* Hero image or gradient fallback */}
      <div class:list={[
        "relative overflow-hidden rounded-t-lg",
        featured ? "md:rounded-l-lg md:rounded-tr-none md:w-1/2 aspect-[16/9] md:aspect-auto" : "aspect-[16/9]"
      ]}>
        {heroImage ? (
          <img
            src={heroImage}
            alt={heroImageAlt || title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class={`w-full h-full bg-gradient-to-br ${gradientColors[gradientIndex]} flex items-center justify-center`}>
            <svg class="w-12 h-12 text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
          </div>
        )}
        {featured && (
          <span class="absolute top-3 left-3 px-2 py-1 text-xs font-semibold rounded-full bg-accent text-bg">
            {t('blog.featured')}
          </span>
        )}
      </div>

      {/* Content */}
      <div class:list={["flex flex-col flex-1 p-5", featured && "md:p-6 md:justify-center"]}>
        <div class="flex items-center gap-3 text-xs text-text-muted mb-3">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {readingTime && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>{readingTime} {t('blog.reading_time')}</span>
            </>
          )}
        </div>
        <h3
          class:list={[
            "font-semibold text-text mb-2 group-hover:text-primary transition-colors line-clamp-2",
            featured ? "text-xl md:text-2xl" : "text-lg"
          ]}
          transition:name={slug ? `blog-title-${slug}` : undefined}
        >
          {title}
        </h3>
        <p class:list={[
          "text-sm text-text-muted flex-1 leading-relaxed",
          featured ? "line-clamp-4" : "line-clamp-3"
        ]}>{description}</p>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.slice(0, 3).map((tag) => (
              <a
                href={`/blog/tags/${encodeURIComponent(tag.toLowerCase())}/`}
                class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors relative z-10"
                onclick="event.stopPropagation();"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </Card>
</a>

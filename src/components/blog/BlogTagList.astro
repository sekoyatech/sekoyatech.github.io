---
import { useTranslations } from '../../i18n/utils';

interface Props {
  tags: { name: string; count: number }[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
const t = useTranslations();
---

<div class="flex flex-wrap gap-2 mb-8">
  <a
    href="/blog/"
    class:list={[
      "px-4 py-2 text-sm font-medium rounded-full border transition-colors",
      !activeTag
        ? "bg-primary text-bg border-primary"
        : "border-border text-text-muted hover:text-primary hover:border-primary/30"
    ]}
  >
    {t('blog.all_tags')}
  </a>
  {tags.map(({ name, count }) => (
    <a
      href={`/blog/tags/${name.toLowerCase()}/`}
      class:list={[
        "px-4 py-2 text-sm font-medium rounded-full border transition-colors",
        activeTag === name.toLowerCase()
          ? "bg-primary text-bg border-primary"
          : "border-border text-text-muted hover:text-primary hover:border-primary/30"
      ]}
    >
      {name} <span class="text-xs opacity-70">({count})</span>
    </a>
  ))}
</div>

---
import Button from '../ui/Button.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations();
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/10 to-secondary/10" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">{t('home.cta.title')}</h2>
    <p class="text-lg text-text-muted max-w-2xl mx-auto mb-8">{t('home.cta.subtitle')}</p>
    <Button href="/contact/" variant="primary" size="lg">{t('home.cta.button')}</Button>
  </div>
</section>

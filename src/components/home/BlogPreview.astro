---
import { getCollection } from 'astro:content';
import Section from '../ui/Section.astro';
import BlogCard from '../blog/BlogCard.astro';
import Button from '../ui/Button.astro';
import { useTranslations } from '../../i18n/utils';
import { calculateReadingTime } from '../../lib/utils';

const t = useTranslations();
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Section background="surface">
  <div class="text-center mb-12" data-reveal>
    <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">{t('home.blog.title')}</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    {posts.map((post) => (
      <BlogCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        href={`/blog/${post.id}/`}
        readingTime={calculateReadingTime(post.body ?? '')}
        slug={post.id}
        heroImage={post.data.heroImage}
        heroImageAlt={post.data.heroImageAlt}
      />
    ))}
  </div>
  <div class="text-center">
    <Button href="/blog/" variant="outline">{t('home.blog.cta')}</Button>
  </div>
</Section>

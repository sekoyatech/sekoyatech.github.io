---
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import { useTranslations } from '../../i18n/utils';
import { SITE } from '../../lib/constants';

const t = useTranslations();

const stats = [
  { value: String(SITE.foundedYear), label: t('stats.founded') },
  { value: '25+', label: t('stats.projects') },
  { value: '15+', label: t('stats.clients') },
  { value: '20+', label: t('stats.technologies') },
];
---

<Section background="surface">
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Text Content -->
    <div data-reveal="left">
      <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">{t('home.about.title')}</h2>
      <p class="text-lg text-text-muted leading-relaxed mb-8">
        {t('home.about.description')}
      </p>
      <Button href="/about/" variant="outline" size="md">
        {t('home.about.cta')}
      </Button>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 gap-6" data-reveal-stagger>
      {stats.map((stat) => (
        <div class="bg-bg border border-border rounded-lg p-6 text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-primary mb-2" data-counter={stat.value}>{stat.value}</div>
          <div class="text-sm text-text-muted font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</Section>

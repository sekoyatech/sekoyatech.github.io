---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations();
---

<button
  type="button"
  class="theme-toggle flex items-center justify-center w-10 h-10 rounded-md text-text-muted hover:text-text hover:bg-surface transition-colors"
  aria-label={t('common.theme_toggle')}
>
  <!-- Sun icon (shown in dark mode → click to switch to light) -->
  <svg class="theme-icon-sun w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  <!-- Moon icon (shown in light mode → click to switch to dark) -->
  <svg class="theme-icon-moon w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<script>
  function initThemeToggles() {
    const buttons = document.querySelectorAll('.theme-toggle');
    const sunIcons = document.querySelectorAll('.theme-icon-sun');
    const moonIcons = document.querySelectorAll('.theme-icon-moon');

    function updateAllIcons() {
      const isLight = document.documentElement.classList.contains('light');
      sunIcons.forEach((icon) => icon.classList.toggle('hidden', isLight));
      moonIcons.forEach((icon) => icon.classList.toggle('hidden', !isLight));
    }

    updateAllIcons();

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const html = document.documentElement;
        const isLight = html.classList.contains('light');

        if (isLight) {
          html.classList.remove('light');
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        } else {
          html.classList.remove('dark');
          html.classList.add('light');
          localStorage.setItem('theme', 'light');
        }

        updateAllIcons();
      });
    });
  }

  initThemeToggles();
  document.addEventListener('astro:after-swap', initThemeToggles);
</script>

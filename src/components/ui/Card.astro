---
interface Props {
  class?: string;
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg' | 'none';
  [key: string]: any;
}

const {
  class: className = '',
  hover = true,
  padding = 'md',
  ...rest
} = Astro.props;

const paddings: Record<string, string> = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const hoverClasses = hover ? 'hover:border-primary/30 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300' : '';
---

<div
  class:list={[
    'bg-surface border border-border rounded-lg',
    paddings[padding],
    hoverClasses,
    className,
  ]}
  {...rest}
>
  <slot />
</div>

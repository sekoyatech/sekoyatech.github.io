---
import { useTranslations } from '../../i18n/utils';
import { GA_MEASUREMENT_ID } from '../../lib/constants';

const t = useTranslations();
---

<div
  class="cookie-consent"
  id="cookie-consent"
  role="dialog"
  aria-label="Cookie consent"
  data-ga-id={GA_MEASUREMENT_ID}
>
  <div class="cookie-consent-inner">
    <p class="cookie-consent-text">{t('cookie.message')}</p>
    <div class="cookie-consent-actions">
      <a href="/privacy-policy/" class="cookie-consent-link">{t('cookie.privacy')}</a>
      <button type="button" class="cookie-consent-btn cookie-consent-reject" data-consent="reject">
        {t('cookie.reject')}
      </button>
      <button type="button" class="cookie-consent-btn cookie-consent-accept" data-consent="accept">
        {t('cookie.accept')}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    function initCookieConsent() {
      var banner = document.getElementById('cookie-consent');
      if (!banner) return;

      var consent = localStorage.getItem('cookie-consent');
      var gaId = banner.getAttribute('data-ga-id');

      if (consent === 'accepted') {
        banner.remove();
        loadGA(gaId);
        return;
      }

      if (consent === 'rejected') {
        banner.remove();
        return;
      }

      // Show banner
      banner.classList.add('visible');

      banner.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-consent]');
        if (!btn) return;

        var choice = btn.getAttribute('data-consent');
        if (choice === 'accept') {
          localStorage.setItem('cookie-consent', 'accepted');
          loadGA(gaId);
        } else {
          localStorage.setItem('cookie-consent', 'rejected');
        }

        banner.classList.remove('visible');
        setTimeout(function () { banner.remove(); }, 300);
      });
    }

    function loadGA(id) {
      if (!id || document.getElementById('ga-script')) return;

      var script = document.createElement('script');
      script.id = 'ga-script';
      script.async = true;
      script.src = 'https://www.googletagmanager.com/gtag/js?id=' + id;
      document.head.appendChild(script);

      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', id);
    }

    // Run on initial load
    initCookieConsent();

    // Re-run after View Transition swap
    document.addEventListener('astro:after-swap', initCookieConsent);
  })();
</script>

---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import { useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  description: string;
  techStack: string[];
  year: number;
  href: string;
  featured?: boolean;
  slug?: string;
}

const { title, description, techStack, year, href, featured = false, slug } = Astro.props;
const t = useTranslations();
---

<a href={href} class="group block" transition:name={slug ? `project-${slug}` : undefined}>
  <Card class:list={['h-full group-hover:border-primary/30', featured && 'ring-1 ring-primary/20']}>
    <div class="flex flex-col h-full">
      {featured && (
        <Badge variant="primary" class="self-start mb-3">Featured</Badge>
      )}
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-lg font-semibold text-text group-hover:text-primary transition-colors" transition:name={slug ? `project-title-${slug}` : undefined}>{title}</h3>
        <span class="text-xs text-text-muted">{year}</span>
      </div>
      <p class="text-sm text-text-muted flex-1 line-clamp-3 leading-relaxed mb-4">{description}</p>
      <div class="flex flex-wrap gap-2">
        {techStack.map((tech) => (
          <Badge variant="muted">{tech}</Badge>
        ))}
      </div>
    </div>
  </Card>
</a>

---
import PageLayout from '../../layouts/PageLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../i18n/utils';
import portfolioData from '../../data/portfolio.json';

const t = useTranslations();

export function getStaticPaths() {
  return portfolioData.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: t('portfolio.title'), href: '/portfolio/' },
  { name: project.title, href: Astro.url.pathname },
];
---

<PageLayout
  title={project.title}
  description={project.description}
  heroTitle={project.title}
  heroDescription={project.description}
  heroTransitionName={`project-title-${project.slug}`}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-4xl">
    <!-- Project metadata -->
    <div class="flex flex-wrap items-center gap-4 mb-8">
      <span class="text-sm text-text-muted">Year: <strong class="text-text">{project.year}</strong></span>
      {project.client && (
        <span class="text-sm text-text-muted">Client: <strong class="text-text">{project.client}</strong></span>
      )}
      {project.url && (
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-sm text-primary hover:underline">
          Visit Live Site &rarr;
        </a>
      )}
    </div>

    <!-- Tech stack badges -->
    <div class="flex flex-wrap gap-2 mb-12">
      {project.techStack.map((tech) => (
        <Badge variant="primary">{tech}</Badge>
      ))}
    </div>

    <!-- Content sections -->
    <div class="mdx-content">
      {project.challenge && (
        <>
          <h2>The Challenge</h2>
          <p>{project.challenge}</p>
        </>
      )}

      {project.approach && project.approach.length > 0 && (
        <>
          <h2>Our Approach</h2>
          {project.approach.map((section) => (
            <p><strong>{section.label}:</strong> {section.text}</p>
          ))}
        </>
      )}

      {project.results && project.results.length > 0 && (
        <>
          <h2>Results</h2>
          <ul>
            {project.results.map((result) => (
              <li>{result}</li>
            ))}
          </ul>
        </>
      )}
    </div>

    <!-- CTA section -->
    <div class="mt-16 pt-8 border-t border-border text-center">
      <h2 class="text-2xl font-bold text-text mb-4">Interested in a similar solution?</h2>
      <p class="text-text-muted mb-6">Let's discuss how we can build something tailored to your needs.</p>
      <Button href="/contact/" variant="primary" size="lg">{t('hero.cta.primary')}</Button>
    </div>
  </div>
</PageLayout>

---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import { useTranslations } from '../i18n/utils';
import { SITE } from '../lib/constants';

const t = useTranslations();

const benefits = [
  {
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Flexible Working',
    description: 'Work remotely or from our office. We trust you to manage your time and deliver great results, wherever you are.',
  },
  {
    icon: 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
    title: 'Continuous Learning',
    description: 'Annual learning budget, conference attendance, and dedicated time for professional development and certifications.',
  },
  {
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
    title: 'Collaborative Culture',
    description: 'A small, focused team where everyone has a voice. Regular code reviews, pair programming, and knowledge sharing sessions.',
  },
  {
    icon: 'M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m5.21-3.789a1.5 1.5 0 112.122 2.122L6.586 20.488a2.548 2.548 0 01-3.586-3.586L12.578 7.33a1.5 1.5 0 012.122 0z',
    title: 'Modern Tech Stack',
    description: 'Work with cutting-edge technologies including Flutter, React, Astro, AI/ML tools, IoT platforms, and cloud-native infrastructure.',
  },
  {
    icon: 'M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z',
    title: 'Competitive Compensation',
    description: 'Fair, market-rate salaries with transparent pay structures. Performance-based bonuses and equity options for key roles.',
  },
  {
    icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
    title: 'Work-Life Balance',
    description: 'Generous paid time off, public holidays, and a culture that respects personal time. No crunch culture, no burnout.',
  },
];
---

<PageLayout
  title={t('careers.title')}
  description={t('careers.subtitle')}
  heroTitle={t('careers.title')}
  heroDescription={t('careers.subtitle')}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: t('careers.title'), href: '/careers/' },
  ]}
>
  <!-- Culture -->
  <section class="mb-16 md:mb-24">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Why Sekoya?</h2>
      <p class="text-lg text-text-muted leading-relaxed mb-6">
        At Sekoya, we believe great software is built by people who are passionate, curious, and empowered to do their best work. We are a small but growing team of engineers, designers, and problem solvers who take pride in craftsmanship and care deeply about the impact of what we build.
      </p>
      <p class="text-lg text-text-muted leading-relaxed">
        We value transparency, continuous improvement, and the kind of honest technical conversations that lead to better decisions. If you thrive in an environment where quality matters, where your ideas are heard, and where you can grow alongside a team that pushes each other to be better, Sekoya might be the right place for you.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="mb-16 md:mb-24">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-8">Benefits & Perks</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {benefits.map((benefit) => (
        <Card hover={false}>
          <div class="flex flex-col h-full">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={benefit.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">{benefit.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{benefit.description}</p>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <!-- Open Positions -->
  <section class="mb-16 md:mb-24">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-8">Open Positions</h2>
    <div class="bg-surface border border-border rounded-xl p-8 md:p-12 text-center">
      <svg class="w-16 h-16 text-text-muted/30 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
      </svg>
      <p class="text-lg text-text-muted mb-2">{t('careers.no_positions')}</p>
      <p class="text-sm text-text-muted">We are always interested in hearing from talented people.</p>
    </div>
  </section>

  <!-- Application CTA -->
  <section class="bg-gradient-to-r from-primary/10 to-secondary/10 rounded-xl p-8 md:p-12 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Don't See the Right Role?</h2>
    <p class="text-lg text-text-muted max-w-2xl mx-auto mb-8">
      We are always looking for exceptional people. Send us your CV and tell us what excites you about technology. If there is a fit, we will reach out.
    </p>
    <Button href={`mailto:${SITE.email}?subject=Career%20Inquiry`} variant="primary" size="lg">
      Send Your CV
    </Button>
  </section>
</PageLayout>

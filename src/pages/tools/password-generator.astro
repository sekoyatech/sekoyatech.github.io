---
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../i18n/utils';
import { toolPageJsonLd } from '../../lib/seo';

const t = useTranslations();

const title = t('tools.passwordGenerator.title');
const description = t('tools.passwordGenerator.description');
---

<PageLayout
  title={title}
  description={description}
  heroTitle={title}
  heroDescription={description}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: t('tools.title'), href: '/tools/' },
    { name: title, href: '/tools/password-generator/' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toolPageJsonLd({ name: title, description, url: '/tools/password-generator/' })} />
  </Fragment>

  <div class="space-y-8 max-w-3xl mx-auto">

    <!-- Mode Selector -->
    <Card hover={false}>
      <div class="flex flex-wrap gap-2">
        <button
          data-pw-mode="password"
          class="px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-primary text-white"
        >
          Password
        </button>
        <button
          data-pw-mode="passphrase"
          class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-text-muted hover:text-text border border-border"
        >
          Passphrase
        </button>
        <button
          data-pw-mode="apikey"
          class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-text-muted hover:text-text border border-border"
        >
          API Key
        </button>
      </div>
    </Card>

    <!-- Generated Output -->
    <Card hover={false} padding="lg">
      <div class="space-y-4">
        <label class="block text-sm font-medium text-text-muted">Generated Output</label>
        <div class="bg-bg rounded-lg p-4 border border-border overflow-x-auto">
          <code data-pw-output class="text-lg font-mono text-primary break-all select-all">
            Generating...
          </code>
        </div>
        <div class="flex flex-wrap gap-3">
          <Button variant="primary" size="sm" data-regenerate>
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182M4.031 9.865H0" />
            </svg>
            Regenerate
          </Button>
          <Button variant="outline" size="sm" data-copy-main>
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
            </svg>
            Copy
          </Button>
        </div>
      </div>
    </Card>

    <!-- Password Options -->
    <Card hover={false} data-mode-panel="password">
      <h3 class="text-lg font-semibold text-text mb-4">Password Options</h3>
      <div class="space-y-5">
        <!-- Length slider -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-sm font-medium text-text">Length</label>
            <span data-pw-length-display class="text-sm font-mono text-primary">16</span>
          </div>
          <input
            type="range"
            data-pw-length
            min="8"
            max="128"
            value="16"
            class="w-full h-2 bg-border rounded-full appearance-none cursor-pointer accent-primary"
          />
          <div class="flex justify-between text-xs text-text-muted mt-1">
            <span>8</span>
            <span>128</span>
          </div>
        </div>

        <!-- Checkboxes -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pw-upper checked class="w-4 h-4 accent-primary" />
            Uppercase (A-Z)
          </label>
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pw-lower checked class="w-4 h-4 accent-primary" />
            Lowercase (a-z)
          </label>
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pw-numbers checked class="w-4 h-4 accent-primary" />
            Numbers (0-9)
          </label>
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pw-symbols checked class="w-4 h-4 accent-primary" />
            Symbols (!@#$...)
          </label>
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer sm:col-span-2">
            <input type="checkbox" data-pw-ambiguous class="w-4 h-4 accent-primary" />
            Exclude ambiguous (0, O, I, l, 1)
          </label>
        </div>
      </div>
    </Card>

    <!-- Passphrase Options -->
    <Card hover={false} data-mode-panel="passphrase" class="hidden">
      <h3 class="text-lg font-semibold text-text mb-4">Passphrase Options</h3>
      <div class="space-y-5">
        <!-- Word count slider -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-sm font-medium text-text">Word Count</label>
            <span data-pp-words-display class="text-sm font-mono text-primary">4</span>
          </div>
          <input
            type="range"
            data-pp-words
            min="3"
            max="10"
            value="4"
            class="w-full h-2 bg-border rounded-full appearance-none cursor-pointer accent-primary"
          />
          <div class="flex justify-between text-xs text-text-muted mt-1">
            <span>3</span>
            <span>10</span>
          </div>
        </div>

        <!-- Separator buttons -->
        <div>
          <label class="block text-sm font-medium text-text mb-2">Separator</label>
          <div class="flex flex-wrap gap-2">
            <button
              data-pp-sep="-"
              class="px-3 py-1.5 rounded-lg text-sm font-mono transition-colors bg-primary text-white"
            >
              - (Hyphen)
            </button>
            <button
              data-pp-sep="_"
              class="px-3 py-1.5 rounded-lg text-sm font-mono transition-colors text-text-muted hover:text-text border border-border"
            >
              _ (Underscore)
            </button>
            <button
              data-pp-sep="."
              class="px-3 py-1.5 rounded-lg text-sm font-mono transition-colors text-text-muted hover:text-text border border-border"
            >
              . (Period)
            </button>
            <button
              data-pp-sep="space"
              class="px-3 py-1.5 rounded-lg text-sm font-mono transition-colors text-text-muted hover:text-text border border-border"
            >
              (Space)
            </button>
          </div>
        </div>

        <!-- Toggles -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pp-caps checked class="w-4 h-4 accent-primary" />
            Capitalize words
          </label>
          <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
            <input type="checkbox" data-pp-number checked class="w-4 h-4 accent-primary" />
            Include a number
          </label>
        </div>
      </div>
    </Card>

    <!-- API Key Options -->
    <Card hover={false} data-mode-panel="apikey" class="hidden">
      <h3 class="text-lg font-semibold text-text mb-4">API Key Options</h3>
      <div class="space-y-5">
        <!-- Format select -->
        <div>
          <label class="block text-sm font-medium text-text mb-2">Format</label>
          <select
            data-ak-format
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm text-text focus:border-primary focus:ring-1 focus:ring-primary outline-none"
          >
            <option value="hex32">Hex (32 chars / 128 bits)</option>
            <option value="hex64">Hex (64 chars / 256 bits)</option>
            <option value="base64_32">Base64 (32 chars)</option>
            <option value="base64_64">Base64 (64 chars)</option>
            <option value="uuid">UUID v4</option>
          </select>
        </div>

        <!-- Prefix input -->
        <div>
          <label class="block text-sm font-medium text-text mb-2">Prefix (optional)</label>
          <input
            type="text"
            data-ak-prefix
            placeholder="e.g. sk_, pk_, api_"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm text-text placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none font-mono"
          />
        </div>
      </div>
    </Card>

    <!-- Strength Meter -->
    <Card hover={false}>
      <h3 class="text-lg font-semibold text-text mb-4">Strength Analysis</h3>
      <div class="space-y-4">
        <!-- Progress bar -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-text">Strength</span>
            <span data-strength-label class="text-sm font-semibold text-text">Calculating...</span>
          </div>
          <div class="w-full h-3 bg-border rounded-full overflow-hidden">
            <div
              data-strength-bar
              class="h-full rounded-full transition-all duration-500 ease-out bg-green-500"
              style="width: 0%"
            ></div>
          </div>
        </div>

        <!-- Details -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-bg rounded-lg p-3 border border-border">
            <div class="text-xs text-text-muted mb-1">Entropy</div>
            <div data-entropy class="text-sm font-mono font-semibold text-text">-- bits</div>
          </div>
          <div class="bg-bg rounded-lg p-3 border border-border">
            <div class="text-xs text-text-muted mb-1">Est. Crack Time</div>
            <div data-crack-time class="text-sm font-mono font-semibold text-text">--</div>
          </div>
        </div>
        <p class="text-xs text-text-muted">
          Crack time assumes 10 billion guesses per second (offline attack with modern hardware).
        </p>
      </div>
    </Card>

    <!-- Bulk Generation -->
    <Card hover={false}>
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-text">Bulk Generation</h3>
        <div class="flex items-center gap-3">
          <label class="text-sm text-text-muted">Count:</label>
          <select
            data-bulk-count
            class="bg-bg border border-border rounded-lg px-2 py-1 text-sm text-text focus:border-primary focus:ring-1 focus:ring-primary outline-none"
          >
            <option value="1">1</option>
            <option value="3">3</option>
            <option value="5" selected>5</option>
            <option value="10">10</option>
            <option value="15">15</option>
            <option value="20">20</option>
          </select>
        </div>
      </div>

      <div data-bulk-list class="mb-4 max-h-80 overflow-y-auto">
        <!-- Bulk items rendered by JS -->
      </div>

      <Button variant="outline" size="sm" data-copy-all>
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
        </svg>
        Copy All
      </Button>
    </Card>

    <!-- Security Notice -->
    <div class="flex items-start gap-3 rounded-lg bg-primary/10 border border-primary/20 p-4">
      <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
      </svg>
      <div>
        <p class="text-sm font-medium text-text">Your passwords never leave your browser.</p>
        <p class="text-xs text-text-muted mt-1">
          All generation is done client-side using <code class="text-primary bg-surface px-1 rounded text-xs font-mono">crypto.getRandomValues()</code> — the Web Crypto API standard for cryptographic randomness. No data is sent to any server.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <Card hover={false} class="text-center">
      <h3 class="text-lg font-semibold text-text mb-2">Building a system that needs enterprise-grade security?</h3>
      <p class="text-sm text-text-muted mb-4">
        We help companies design and implement secure authentication systems, API key management, and more.
      </p>
      <Button href="/services/custom-app-development/" variant="primary" size="md">
        Talk to Our Team
        <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </Button>
    </Card>

  </div>

  <script src="../../scripts/tools/password-generator.ts"></script>
</PageLayout>

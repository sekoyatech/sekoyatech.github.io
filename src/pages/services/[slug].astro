---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import ServiceCard from '../../components/services/ServiceCard.astro';
import { useTranslations } from '../../i18n/utils';
import { serviceJsonLd, faqPageJsonLd } from '../../lib/seo';
import { SITE } from '../../lib/constants';

const serviceFaqs: Record<string, { question: string; answer: string }[]> = {
  'mobile-web-development': [
    { question: 'What technologies do you use for mobile development?', answer: 'We primarily use Flutter and Dart for cross-platform mobile development, along with React Native for specific use cases. For web applications, we work with React, Next.js, Astro, and Vue.js.' },
    { question: 'How long does it take to develop a mobile app?', answer: 'A typical mobile app takes 3-6 months from concept to launch, depending on complexity. Simple apps can be delivered in 8-12 weeks, while complex enterprise apps may take 6-12 months.' },
    { question: 'Do you develop for both iOS and Android?', answer: 'Yes. Using Flutter, we build a single codebase that deploys natively to both iOS and Android, ensuring consistent quality across platforms while reducing development time and cost.' },
  ],
  'custom-app-development': [
    { question: 'What is custom software development?', answer: 'Custom software development is the process of designing, creating, and maintaining software specifically built for your organization\'s unique requirements, as opposed to using off-the-shelf commercial solutions.' },
    { question: 'How much does custom software development cost?', answer: 'Costs vary significantly based on scope and complexity. A basic custom application typically starts from $20,000-50,000, while enterprise-grade solutions can range from $100,000 to $500,000+. We provide detailed estimates after understanding your requirements.' },
    { question: 'Why choose custom software over off-the-shelf solutions?', answer: 'Custom software is built specifically for your workflows, offers unlimited scalability, provides complete ownership and control, and eliminates recurring license fees. It\'s ideal when existing solutions don\'t fit your unique business processes.' },
  ],
  'software-consultancy': [
    { question: 'What does software consultancy include?', answer: 'Our consultancy services include technology stack evaluation, architecture review, code audits, digital transformation strategy, cloud migration planning, and technical team mentoring.' },
    { question: 'When should a company hire a software consultant?', answer: 'Companies benefit from consultancy when starting new projects, modernizing legacy systems, facing technical debt, planning cloud migrations, or needing expert guidance on technology decisions.' },
  ],
  'project-management': [
    { question: 'What project management methodologies do you use?', answer: 'We primarily use Agile/Scrum for software projects, with Kanban for maintenance and support work. For larger enterprise projects, we can adapt SAFe (Scaled Agile Framework) or hybrid approaches.' },
    { question: 'How do you ensure project delivery on time?', answer: 'We use sprint-based delivery with 2-week iterations, regular stakeholder demos, risk management practices, and transparent reporting via project management tools like Jira and Linear.' },
  ],
  'iot-solutions': [
    { question: 'What industries do your IoT solutions serve?', answer: 'We serve manufacturing, logistics, agriculture, healthcare, and smart building sectors. Our IoT solutions include sensor integration, real-time monitoring dashboards, predictive maintenance, and edge computing.' },
    { question: 'What IoT protocols and platforms do you work with?', answer: 'We work with MQTT, CoAP, HTTP/REST, and WebSocket protocols. Our platform experience includes AWS IoT Core, Azure IoT Hub, and custom edge computing solutions.' },
  ],
  'machine-learning': [
    { question: 'What types of ML solutions do you build?', answer: 'We build predictive analytics models, recommendation systems, anomaly detection, natural language processing pipelines, computer vision applications, and time-series forecasting systems.' },
    { question: 'Do you handle the entire ML pipeline?', answer: 'Yes, we handle end-to-end ML projects: data collection and cleaning, feature engineering, model selection and training, evaluation, deployment to production, and ongoing monitoring and retraining.' },
  ],
  'artificial-intelligence': [
    { question: 'How can AI benefit my business?', answer: 'AI can automate repetitive tasks, provide intelligent customer support via chatbots, optimize operations through predictive analytics, enhance decision-making with data-driven insights, and create personalized user experiences.' },
    { question: 'What AI technologies do you specialize in?', answer: 'We specialize in large language model (LLM) integration, natural language processing, computer vision, generative AI applications, and intelligent automation using tools like OpenAI API, Hugging Face, TensorFlow, and PyTorch.' },
  ],
  'devops-cloud': [
    { question: 'Which cloud platforms do you support?', answer: 'We work with AWS, Microsoft Azure, and Google Cloud Platform. We also support multi-cloud and hybrid cloud architectures, helping you choose the best platform for your needs.' },
    { question: 'What does your DevOps service include?', answer: 'Our DevOps services include CI/CD pipeline setup (GitHub Actions, GitLab CI, Jenkins), containerization (Docker, Kubernetes), infrastructure as code (Terraform, Pulumi), monitoring (Grafana, Prometheus), and 24/7 production support.' },
  ],
};

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations();

const allServices = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const relatedServices = allServices.filter((s) => s.id !== entry.id).slice(0, 3);
const faqs = serviceFaqs[entry.id] || [];
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  heroTitle={entry.data.title}
  heroDescription={entry.data.description}
  heroTransitionName={`service-title-${entry.id}`}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: t('services.title'), href: '/services/' },
    { name: entry.data.title, href: `/services/${entry.id}/` },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceJsonLd({
      title: entry.data.title,
      description: entry.data.description,
      url: `/services/${entry.id}/`,
    })} />
    {faqs.length > 0 && (
      <script type="application/ld+json" set:html={faqPageJsonLd(faqs)} />
    )}
  </Fragment>

  <!-- Structured Data (in body - Google accepts JSON-LD in body) -->
  {faqs.length > 0 && (
    <script type="application/ld+json" set:html={faqPageJsonLd(faqs)} />
  )}

  <!-- Features -->
  {entry.data.features.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-text mb-6">Key Features</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {entry.data.features.map((feature) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-text-muted">{feature}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- MDX Content -->
  <div class="mdx-content mb-16">
    <Content />
  </div>

  <!-- FAQ Section -->
  {faqs.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-surface border border-border rounded-lg">
            <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 text-text font-medium hover:text-primary transition-colors">
              {faq.question}
              <svg class="w-5 h-5 flex-shrink-0 text-text-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-muted leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-surface border border-border rounded-xl p-8 md:p-12 text-center mb-16">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Interested in {entry.data.title}?</h2>
    <p class="text-text-muted max-w-2xl mx-auto mb-8">
      Let's discuss how we can help your business with our {entry.data.title.toLowerCase()} expertise. Get in touch for a free consultation.
    </p>
    <Button href="/contact/" variant="primary" size="lg">{t('hero.cta.primary')}</Button>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section>
      <h2 class="text-2xl font-bold text-text mb-8">Other Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedServices.map((service) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            icon={service.data.icon}
            href={`/services/${service.id}/`}
          />
        ))}
      </div>
    </section>
  )}
</PageLayout>

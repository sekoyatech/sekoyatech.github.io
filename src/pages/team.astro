---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import TeamMember from '../components/team/TeamMember.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations();
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title={t('team.title')}
  description={t('team.subtitle')}
  heroTitle={t('team.title')}
  heroDescription={t('team.subtitle')}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: t('team.title'), href: '/team/' },
  ]}
>
  <div class="flex flex-col gap-8 md:gap-12">
    {team.map((member, index) => (
      <TeamMember
        name={member.data.name}
        role={member.data.role}
        bio={member.data.bio}
        photo={member.data.photo}
        linkedin={member.data.linkedin}
        github={member.data.github}
        skills={member.data.skills}
        index={index}
      />
    ))}
  </div>
</PageLayout>

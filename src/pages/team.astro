---
import PageLayout from '../layouts/PageLayout.astro';
import TeamMember from '../components/team/TeamMember.astro';
import { useTranslations } from '../i18n/utils';
import teamData from '../data/team.json';

const t = useTranslations();
const team = teamData.sort((a, b) => a.order - b.order);
---

<PageLayout
  title={t('team.title')}
  description={t('team.subtitle')}
  heroTitle={t('team.title')}
  heroDescription={t('team.subtitle')}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: t('team.title'), href: '/team/' },
  ]}
>
  <!-- Team Manifesto -->
  <section class="mb-12 md:mb-20 max-w-3xl mx-auto text-center">
    <p class="text-lg md:text-xl text-text-muted leading-relaxed mb-6">
      We are a young, creative, and free-spirited crew who live and breathe technology.
      At Sekoya, writing code is not just work — it is how we express ourselves.
      Every line we ship carries our excitement, every product reflects our obsession with craft.
    </p>
    <p class="text-lg md:text-xl text-text-muted leading-relaxed">
      We don't follow trends — we chase the ideas that keep us up at night.
      United by curiosity and driven by passion, we turn bold visions into software that actually matters.
    </p>
  </section>

  <div class="flex flex-col gap-8 md:gap-12">
    {team.map((member, index) => (
      <TeamMember
        name={member.name}
        role={member.role}
        bio={member.bio}
        photo={member.photo}
        linkedin={member.linkedin}
        github={member.github}
        skills={member.skills}
        index={index}
      />
    ))}
  </div>
</PageLayout>

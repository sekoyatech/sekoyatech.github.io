---
import BaseLayout from './BaseLayout.astro';
import BlogHero from '../components/blog/BlogHero.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import GiscusComments from '../components/blog/GiscusComments.astro';
import { blogPostingJsonLd, breadcrumbJsonLd } from '../lib/seo';
import { useTranslations } from '../i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  heroImage?: string;
  heroImageAlt?: string;
  tags?: string[];
  readingTime: number;
  slug?: string;
  headings?: Heading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'Sekoya Team',
  heroImage,
  heroImageAlt,
  tags = [],
  readingTime,
  slug,
  headings = [],
} = Astro.props;

const t = useTranslations();

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: title, href: Astro.url.pathname },
];

const shareUrl = encodeURIComponent(`https://sekoya.tech${Astro.url.pathname}`);
const shareTitle = encodeURIComponent(title);

const hasToC = headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={blogPostingJsonLd({
      title,
      description,
      url: Astro.url.pathname,
      pubDate,
      updatedDate,
      author,
      image: heroImage,
    })} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd(breadcrumbs)} />
  </Fragment>

  <article class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    {/* Breadcrumb */}
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-text-muted">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span aria-hidden="true">/</span>}
            {i === breadcrumbs.length - 1 ? (
              <span aria-current="page" class="text-text">{crumb.name}</span>
            ) : (
              <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    {/* Hero section */}
    <BlogHero
      title={title}
      pubDate={pubDate}
      updatedDate={updatedDate}
      author={author}
      readingTime={readingTime}
      tags={tags}
      heroImage={heroImage}
      heroImageAlt={heroImageAlt}
      slug={slug}
    />

    {/* Mobile ToC */}
    <TableOfContents headings={headings} mode="mobile" />

    {/* 2-column layout: content + ToC sidebar */}
    <div class:list={["flex gap-12", hasToC && "lg:grid lg:grid-cols-[1fr_240px]"]}>
      {/* Main content */}
      <div class="min-w-0 max-w-none">
        <div class="mdx-content">
          <slot />
        </div>

        {/* Share Links */}
        <footer class="mt-16 pt-8 border-t border-border">
          <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-4">{t('blog.share')}</h2>
          <div class="flex gap-4">
            <a
              href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted hover:text-primary transition-colors"
              aria-label="Share on X/Twitter"
            >
              X / Twitter
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted hover:text-primary transition-colors"
              aria-label="Share on LinkedIn"
            >
              LinkedIn
            </a>
            <a
              href={`mailto:?subject=${shareTitle}&body=${shareUrl}`}
              class="text-text-muted hover:text-primary transition-colors"
              aria-label="Share via Email"
            >
              Email
            </a>
          </div>
        </footer>

        {/* Related Posts */}
        <RelatedPosts currentTags={tags} currentSlug={slug ?? ''} />

        {/* Comments */}
        <GiscusComments />
      </div>

      {/* Desktop ToC sidebar */}
      {hasToC && (
        <aside class="hidden lg:block">
          <TableOfContents headings={headings} mode="desktop" />
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
